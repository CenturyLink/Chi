extends ../layout.pug

block scripts
  script(src='../../../js/chi.js')
  script(src='../../../chi-marketing-icons.js')
block variables
  - var title = 'App Layout'

block content
  .chi-grid.-no-gutter.-w--100
    .chi-col.-w--12.-mb--2
      h3 Base
      .test-layout-base.-bg--none.-s--3.-p--0
        .chi-main.-connect
          .chi-main__header
            .chi-main__header-start
              .chi-main__title
                .chi-main__title-heading Page Title
          .chi-main__content
            .-d--flex.-align-items--center.-justify-content--center(style='height:10rem;')
              | Page content goes here
          footer.chi-footer
            .chi-footer__content
              .chi-footer__internal
                .chi-footer__internal-content
                  .chi-dropdown.chi-footer__language
                    a#language-dropdown-button.chi-button.-icon.-flat.-light.-sm.chi-dropdown__trigger(data-position='top-start' aria-label='Select your preferred language')
                      .chi-button__content
                        i.chi-icon.icon-globe-network-outline(aria-hidden='true')
                        span English
                    .chi-dropdown__menu.-w--sm.-text--body
                      a.chi-dropdown__menu-item.-active(href='#') English
                      a.chi-dropdown__menu-item(href='#') Español
                      a.chi-dropdown__menu-item(href='#') Português
                      a.chi-dropdown__menu-item(href='#') Français
                      a.chi-dropdown__menu-item(href='#') Deutsch
                      a.chi-dropdown__menu-item(href='#') 简体中文
                      a.chi-dropdown__menu-item(href='#') 日本語
                  .chi-footer__links
                    ul
                      li
                        a(href='https://www.lumen.com/en-us/about.html') About Us
                      li
                        a(href='https://www.centurylink.com/aboutus/community/community-development/programs-for-customers-with-disabilities.html') Accessibility
                      li
                        a(href='https://jobs.lumen.com' target='_blank') Careers
                      li
                        a(href='https://www.lumen.com/en-us/contact-us.html') Contact Us
